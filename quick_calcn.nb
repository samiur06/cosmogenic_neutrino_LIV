Cell[BoxData[
 RowBox[{
  RowBox[{"makechi2compare", "[", "N0_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "x", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"exp", "=", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"ChiSquareDistribution", "[", "1", "]"}], ",", " ", "0.95"}],
         "]"}], "==", 
       RowBox[{"2", "*", 
        RowBox[{"(", 
         RowBox[{"x", "-", "N0", "+", 
          RowBox[{"N0", "*", 
           RowBox[{"Log", "[", 
            RowBox[{"N0", "/", "x"}], "]"}]}]}], ")"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"x", "/.", 
      RowBox[{"Solve", "[", 
       RowBox[{"exp", ",", 
        RowBox[{"Assumptions", "->", 
         RowBox[{"x", ">", "0"}]}]}], "]"}]}]}]}], "]"}]}]], "Input",
