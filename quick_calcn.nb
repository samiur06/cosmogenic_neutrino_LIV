Cell["oscillation", "Subsection",
 CellChangeTimes->{{3.982780090387497*^9, 
  3.982780092797682*^9}},ExpressionUUID->"6a931d8a-4ed6-4c3e-8b8d-\
98a731ae7e4e"],

Cell[BoxData[
 RowBox[{"mix2new", "//", "StandardForm"}]], "Input",
 CellChangeTimes->{{3.982780406005368*^9, 3.982780411535377*^9}},
 CellLabel->
  "In[770]:=",ExpressionUUID->"48f15868-7997-478d-afc7-c0d578c7bb91"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mix2newfunc", "[", 
   RowBox[{
   "En_", ",", "GF_", ",", "ne_", ",", "np_", ",", "dm21_", ",", "\[Theta]_", 
    ",", "x_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          SqrtBox["2"], " ", "En", " ", "GF", " ", "ne"}], "-", 
         RowBox[{"dm21", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "\[Theta]"}], "]"}]}], "-", 
         RowBox[{"\[Sqrt]", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["dm21", "2"], "+", 
            RowBox[{"8", " ", 
             SuperscriptBox["En", "2"], " ", 
             SuperscriptBox["GF", "2"], " ", 
             SuperscriptBox["ne", "2"]}], "+", 
            RowBox[{"32", " ", 
             SuperscriptBox["En", "2"], " ", 
             SuperscriptBox["GF", "2"], " ", 
             SuperscriptBox["np", "2"], " ", 
             SuperscriptBox["x", "2"]}], "-", 
            RowBox[{"4", " ", 
             SqrtBox["2"], " ", "dm21", " ", "En", " ", "GF", " ", "ne", " ", 
             
             RowBox[{"Cos", "[", 
              RowBox[{"2", " ", "\[Theta]"}], "]"}]}], "+", 
            RowBox[{"8", " ", 
             SqrtBox["2"], " ", "dm21", " ", "En", " ", "GF", " ", "np", " ", 
             "x", " ", 
             RowBox[{"Sin", "[", 
              RowBox[{"2", " ", "\[Theta]"}], "]"}]}]}], ")"}]}]}], ")"}], 
       "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Sqrt]", 
          RowBox[{"(", 
           RowBox[{"4", "+", 
            SuperscriptBox[
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "2"}], " ", 
                  SqrtBox["2"], " ", "En", " ", "GF", " ", "ne"}], "+", 
                 RowBox[{"dm21", " ", 
                  RowBox[{"Cos", "[", 
                   RowBox[{"2", " ", "\[Theta]"}], "]"}]}], "+", 
                 RowBox[{"\[Sqrt]", 
                  RowBox[{"(", 
                   RowBox[{
                    SuperscriptBox["dm21", "2"], "+", 
                    RowBox[{"8", " ", 
                    SuperscriptBox["En", "2"], " ", 
                    SuperscriptBox["GF", "2"], " ", 
                    SuperscriptBox["ne", "2"]}], "+", 
                    RowBox[{"32", " ", 
                    SuperscriptBox["En", "2"], " ", 
                    SuperscriptBox["GF", "2"], " ", 
                    SuperscriptBox["np", "2"], " ", 
                    SuperscriptBox["x", "2"]}], "-", 
                    RowBox[{"4", " ", 
                    SqrtBox["2"], " ", "dm21", " ", "En", " ", "GF", " ", 
                    "ne", " ", 
                    RowBox[{"Cos", "[", 
                    RowBox[{"2", " ", "\[Theta]"}], "]"}]}], "+", 
                    RowBox[{"8", " ", 
                    SqrtBox["2"], " ", "dm21", " ", "En", " ", "GF", " ", 
                    "np", " ", "x", " ", 
                    RowBox[{"Sin", "[", 
                    RowBox[{"2", " ", "\[Theta]"}], "]"}]}]}], ")"}]}]}], 
                ")"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", " ", 
                  SqrtBox["2"], " ", "En", " ", "GF", " ", "np", " ", "x"}], 
                 "+", 
                 RowBox[{"dm21", " ", 
                  RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
                  RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ")"}]}], "]"}], 
             "2"]}], ")"}]}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", 
            SqrtBox["2"], " ", "En", " ", "GF", " ", "np", " ", "x"}], "+", 
