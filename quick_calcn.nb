Cell["test LIV similar resonance as NSI", "Subsection",
 CellChangeTimes->{{3.982771351328711*^9, 
  3.982771381179678*^9}},ExpressionUUID->"ae8ce58e-24cf-4666-9137-\
e696024ea056"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "nucleondensity", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"numearthnucldensity", "=", 
   RowBox[{"5", "*", 
    SuperscriptBox["10", 
     RowBox[{"24", " "}]], 
    RowBox[{"(*", 
     RowBox[{"number", " ", "of", " ", "nucleons", " ", "in", " ", "per", " ", 
      RowBox[{"cm", "^", "3"}]}], "*)"}], "*", " ", "7.7", "*", 
    SuperscriptBox["10", 
     RowBox[{"-", "42"}]]}]}], " ", 
  RowBox[{"(*", 
   SuperscriptBox["GeV", 
    RowBox[{"-", "3"}]], "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqn", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"nsimutau", " ", 
      SqrtBox["2"], "GF", " ", "nucleondensity"}], "==", 
     RowBox[{
      SuperscriptBox["En", 
       RowBox[{"d", "-", "3"}]], 
      RowBox[{"(", 
       FractionBox["1", "4"], ")"}], "*", "dm2", "*", 
      RowBox[{"En", "^", 
       RowBox[{"(", 
        RowBox[{"(", 
         RowBox[{"2", "-", "d"}], ")"}], ")"}]}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "\[Theta]"}], "]"}]}]}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"GF", "->", 
       RowBox[{"1.16", "*", 
        SuperscriptBox["10", 
         RowBox[{"-", "5"}]]}]}], " ", 
      RowBox[{"(*", 
       SuperscriptBox["GeV", 
        RowBox[{"-", "2"}]], "*)"}], ",", 
      RowBox[{"dm2", "->", 
       RowBox[{"2.5", "*", 
        SuperscriptBox["10", 
         RowBox[{"-", "3"}]], "*", 
        SuperscriptBox["10", 
         RowBox[{"-", "18"}]]}]}], ",", 
      RowBox[{"\[Theta]", "->", 
       RowBox[{"45", " ", "Degree"}]}], ",", 
      RowBox[{"nucleondensity", "->", "numearthnucldensity"}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nsimutau", "/.", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{"eqn", ",", "nsimutau"}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], "//", "StandardForm"}]}], "Input",
 CellChangeTimes->{{3.982764773717901*^9, 3.982764897206976*^9}, {
