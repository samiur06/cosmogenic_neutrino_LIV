Cell["set up mixing matrix ", "Subsection",
 CellChangeTimes->{{3.981203508106543*^9, 3.9812035113509207`*^9}, {
  3.981203603850943*^9, 3.981203605870635*^9}, {3.982233890071024*^9, 
  3.982233921022071*^9}},ExpressionUUID->"8469e0fb-12ff-414e-9254-\
97f29913d7cb"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "mix2", ",", "free2", ",", "free2v2", ",", "mat2", ",", "vals", ",", 
   "vecs"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mix2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}]}], ";", 
  RowBox[{"free2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"dm21", "/", 
        RowBox[{"(", 
         RowBox[{"2", "En"}], ")"}]}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"free2v2", "=", 
   RowBox[{"mix2", ".", "free2", ".", 
    RowBox[{"Transpose", "[", "mix2", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mat2", "=", 
   RowBox[{"free2v2", "+", 
    RowBox[{"ReplaceAll", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"+", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"d", "+", "1"}]]}], 
       SuperscriptBox["En", 
        RowBox[{"d", "-", "3"}]], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"aee", ",", "aem"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"aem", ",", "amm"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"d", "->", "5"}], ","}], "*)"}], 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"aee", "->", "0"}], ",", 
         RowBox[{"aem", "->", "x"}], " ", ",", 
         RowBox[{"amm", "->", "0"}]}], "*)"}], "}"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"vals", ",", "vecs"}], "}"}], "=", 
    RowBox[{"Eigensystem", "[", "mat2", "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"normvecs", "=", 
     RowBox[{"{", "}"}]}], ";"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"normvecs", "=", 
   RowBox[{"Normalize", "/@", "vecs"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ord", "=", 
    RowBox[{"Ordering", "[", "vals", "]"}]}], ";"}], 
  "          "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mix2new", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"normvecs", "[", 
     RowBox[{"[", "ord", "]"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mix2new", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"mix2new", ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         SuperscriptBox["dm21", "2"], ">", "0"}], ",", 
        RowBox[{"dm21", ">", "0"}], ",", 
        RowBox[{"x", ">", "0"}], ",", 
        RowBox[{"\[Theta]", ">", "0"}], ",", 
        RowBox[{"En", ">", "0"}]}], "}"}]}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9822317015234537`*^9, 3.982231705745023*^9}, 
   3.982231737955529*^9, 3.982232692448048*^9},
 CellLabel->
  "In[1137]:=",ExpressionUUID->"744bcae1-9013-4b3f-8bb2-2d4af72eced0"]
}, Open  ]],

