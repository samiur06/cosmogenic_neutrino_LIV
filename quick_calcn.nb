Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"probavgEn", "[", 
    RowBox[{"a_", ",", "b_", ",", "En_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "mat", ",", "freeterm", ",", "Hamfunc", ",", "dm21", ",", "dm31", ",", 
       "d", ",", "pmns", ",", "aee", ",", "amm", ",", "att", ",", "aem", ",", 
       "aet", ",", "amt"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Hamfunc", "[", 
        RowBox[{"dm21_", ",", "dm31_"}], "]"}], ":=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"dm21", "/", 
            RowBox[{"(", 
             RowBox[{"2", "En"}], ")"}]}], ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", 
           RowBox[{"dm31", "/", 
            RowBox[{"(", 
             RowBox[{"2", "En"}], ")"}]}]}], "}"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"freeterm", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"U", "[", "0", "]"}], ".", 
         RowBox[{"Hamfunc", "[", 
          RowBox[{"dm21", ",", "dm31"}], "]"}], ".", 
         RowBox[{"ConjugateTranspose", "[", 
          RowBox[{"U", "[", "0", "]"}], "]"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"dm21", "->", 
           RowBox[{"7.5", "*", 
            SuperscriptBox["10", 
             RowBox[{"-", "5"}]], "*", 
            SuperscriptBox["10", 
             RowBox[{"-", "18"}]]}]}], ",", 
          RowBox[{"dm31", "->", 
           RowBox[{"2.5", "*", 
            SuperscriptBox["10", 
             RowBox[{"-", "3"}]], "*", 
            SuperscriptBox["10", 
             RowBox[{"-", "18"}]]}]}]}], "}"}]}]}], ";", 
      RowBox[{"mat", "=", 
       RowBox[{"freeterm", "+", 
        RowBox[{"ReplaceAll", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["En", 
             RowBox[{"d", "-", "3"}]]}], 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"aee", ",", "aem", ",", "aet"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"aem", ",", "amm", ",", "amt"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"aet", ",", "amt", ",", "att"}], "}"}]}], "}"}]}], ",", 
          
          RowBox[{"{", 
           RowBox[{
            RowBox[{"dm21", "->", 
             RowBox[{"7.5", "*", 
              SuperscriptBox["10", 
               RowBox[{"-", "5"}]], "*", 
              SuperscriptBox["10", 
               RowBox[{"-", "18"}]]}]}], ",", 
            RowBox[{"dm31", "->", 
             RowBox[{"2.5", "*", 
              SuperscriptBox["10", 
               RowBox[{"-", "3"}]], "*", 
              SuperscriptBox["10", 
               RowBox[{"-", "18"}]]}]}], 
            RowBox[{"(*", 
             RowBox[{",", 
              RowBox[{"En", "->", 
               RowBox[{"2.6", " ", 
                SuperscriptBox["10", 
                 RowBox[{"7", " "}]]}]}]}], "*)"}], 
            RowBox[{"(*", 
             RowBox[{"in", " ", "GeV"}], "*)"}], ",", 
            RowBox[{"d", "->", "4"}], ",", 
            RowBox[{"aee", "->", "0"}], ",", 
            RowBox[{"aem", "->", "0"}], ",", 
            RowBox[{"aet", "->", "0"}], ",", 
            RowBox[{"amm", "->", "0"}], ",", 
            RowBox[{"amt", "->", 
             SuperscriptBox["10", 
              RowBox[{"-", "36"}]]}], ",", 
            RowBox[{"att", "->", "0"}]}], "}"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"vals", ",", "vecs"}], "}"}], "=", 
       RowBox[{"Eigensystem", "[", "mat", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ord", "=", 
       RowBox[{"Ordering", "[", "vals", "]"}]}], ";", "          ", 
      RowBox[{"(*", 
       RowBox[{
       "indices", " ", "that", " ", "sort", " ", "eigenvalues", " ", 
        "ascending"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"valsSorted", "=", 
       RowBox[{"vals", "[", 
        RowBox[{"[", "ord", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"pmns", "=", 
       RowBox[{"Transpose", "[", 
        RowBox[{"vecs", "[", 
         RowBox[{"[", "ord", "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{
          RowBox[{"ConjugateTranspose", "[", "pmns", "]"}], ".", "mat", ".", 
          "pmns"}], "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          RowBox[{"Abs", "[", 
           RowBox[{"pmns", "[", 
            RowBox[{"[", 
             RowBox[{"a", ",", "i"}], "]"}], "]"}], "]"}], "2"], 
