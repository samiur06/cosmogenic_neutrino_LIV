Cell[BoxData[
 RowBox[{
  RowBox[{"evol", "[", 
   RowBox[{"L_", ",", "En_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", "x_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "GF", ",", "ne", ",", "np", ",", "dm21", ",", "\[Theta]", ",", "makemix",
       ",", "tadaout", ",", "prob"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"2", "x2", " ", "mixing", " ", "matrix"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"makemix", " ", "=", " ", 
      RowBox[{
       RowBox[{"mix2newfunc", "[", 
        RowBox[{
        "En", ",", "GF", ",", "ne", ",", "np", ",", "dm21", ",", "\[Theta]", 
         ",", "x"}], "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"GF", "->", 
          RowBox[{"1.16", "*", 
           SuperscriptBox["10", 
            RowBox[{"-", "5"}]]}]}], " ", 
         RowBox[{"(*", 
          SuperscriptBox["GeV", 
           RowBox[{"-", "2"}]], "*)"}], ",", 
         RowBox[{"dm21", "->", 
          RowBox[{"2.5", "*", 
           SuperscriptBox["10", 
            RowBox[{"-", "3"}]]}]}], ",", 
         RowBox[{"\[Theta]", "->", 
          RowBox[{"45", " ", "Degree"}]}], ",", 
         RowBox[{"np", "->", "numearthnucldensity"}], ",", 
         RowBox[{"ne", "->", "numearthnucldensity"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", "makemix", "]"}], ";"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"tadaout", "=", 
        RowBox[{
         RowBox[{"makemix", ".", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], " ", "1.267", 
                FractionBox[
                 RowBox[{"dm21", " ", "L"}], "En"]}], "]"}]}], "}"}]}], "}"}],
           ".", 
          RowBox[{"ConjugateTranspose", "[", "makemix", "]"}]}], "/.", 
         RowBox[{"dm21", "->", 
          RowBox[{"2.5", "*", 
           SuperscriptBox["10", 
            RowBox[{"-", "3"}]]}]}]}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"tadaout", "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"makemix", "[", 
          RowBox[{"[", 
           RowBox[{"\[Alpha]", ",", "1"}], "]"}], "]"}], 
         RowBox[{"Conjugate", "[", 
          RowBox[{"makemix", "[", 
           RowBox[{"[", 
            RowBox[{"\[Beta]", ",", "1"}], "]"}], "]"}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"makemix", "[", 
          RowBox[{"[", 
           RowBox[{"\[Alpha]", ",", "2"}], "]"}], "]"}], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "I"}], " ", "1.267", 
           FractionBox[
            RowBox[{"dm21", " ", "L"}], "En"]}], "]"}], 
         RowBox[{"Conjugate", "[", 
          RowBox[{"makemix", "[", 
           RowBox[{"[", 
            RowBox[{"\[Beta]", ",", "2"}], "]"}], "]"}], "]"}]}]}], "/.", 
       RowBox[{"dm21", "->", 
        RowBox[{"2.5", "*", 
         SuperscriptBox["10", 
          RowBox[{"-", "3"}]]}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"prob", "=", 
      RowBox[{"tadaout", " ", 
       RowBox[{"Conjugate", "[", "tadaout", "]"}]}]}], ";", 
     "\[IndentingNewLine]", "prob"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "]"}]}]], "Input",
