Cell[CellGroupData[{

Cell["Find  resonance in H0+Hmatter+NSI", "Subsection",
 CellChangeTimes->{{3.982771351328711*^9, 
  3.982771413327202*^9}},ExpressionUUID->"90e0a040-9761-4196-90dc-\
f27f96ac37b1"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "mix2", ",", "free2", ",", "free2v2", ",", "mat2", ",", "vals", ",", 
   "vecs"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mix2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}]}], ";", 
  RowBox[{"free2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"dm21", "/", 
        RowBox[{"(", 
         RowBox[{"2", "En"}], ")"}]}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"free2v2", "=", 
   RowBox[{"mix2", ".", "free2", ".", 
    RowBox[{"Transpose", "[", "mix2", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"matter2", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SqrtBox["2"], "GF", " ", "ne"}], " ", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mat2", "=", 
   RowBox[{"free2v2", "+", "matter2", "+", 
    RowBox[{"ReplaceAll", "[", 
     RowBox[{
      RowBox[{
       SqrtBox["2"], "GF", " ", "np", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"aee", ",", "aem"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"aem", ",", "amm"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"aee", "->", "0"}], ",", 
        RowBox[{"aem", "->", "x"}], " ", ",", 
        RowBox[{"amm", "->", "0"}]}], "}"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"vals", ",", "vecs"}], "}"}], "=", 
    RowBox[{"Eigensystem", "[", "mat2", "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"normvecs", "=", 
     RowBox[{"{", "}"}]}], ";"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"normvecs", "=", 
   RowBox[{"Normalize", "/@", "vecs"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ord", "=", 
    RowBox[{"Ordering", "[", "vals", "]"}]}], ";"}], 
  "          "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mix2new", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"normvecs", "[", 
     RowBox[{"[", "ord", "]"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mix2new", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"mix2new", ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         SuperscriptBox["dm21", "2"], ">", "0"}], ",", 
        RowBox[{"dm21", ">", "0"}], ",", 
        RowBox[{"x", ">", "0"}], ",", 
        RowBox[{"\[Theta]", ">", "0"}], ",", 
        RowBox[{"En", ">", "0"}]}], "}"}]}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9822317015234537`*^9, 3.982231705745023*^9}, 
   3.982231737955529*^9, 3.982232692448048*^9, {3.982771471556568*^9, 
   3.982771516718731*^9}, {3.982771629065771*^9, 3.982771642289682*^9}, {
   3.982771678303253*^9, 3.982771711489553*^9}, {3.982771811696474*^9, 
   3.982771812716124*^9}},
 CellLabel->
  "In[593]:=",ExpressionUUID->"a5644b51-65f5-4d39-a5fa-92916fed5bae"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"mix2new", "[", 
     RowBox[{"[", 
      RowBox[{"2", ",", "1"}], "]"}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "->", "0"}], ",", 
      RowBox[{"ne", "->", "0"}], ",", 
      RowBox[{"np", "->", "0"}]}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"dm21", ">", "0"}], ",", 
     RowBox[{
      FractionBox["\[Pi]", "2"], ">", "\[Theta]", ">", "0"}]}], "}"}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9827717244746733`*^9, 3.982771752113883*^9}, {
  3.982771824695425*^9, 3.9827719392236233`*^9}, {3.982778350549222*^9, 
  3.982778405073112*^9}},
 CellLabel->
  "In[620]:=",ExpressionUUID->"01d83fab-7dac-478b-8f0d-10aac6b23fda"],

Cell[BoxData[
 FormBox[
  RowBox[{"sin", "(", "\[Theta]", ")"}], TraditionalForm]], "Output",
 CellChangeTimes->{
  3.98277172700231*^9, {3.982771817285625*^9, 3.982771939858564*^9}, 
   3.982778321546186*^9, {3.982778356034728*^9, 3.982778405630061*^9}},
 CellLabel->
  "Out[620]=",ExpressionUUID->"07ec99e7-6312-400b-9912-1f265716f73e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"simp11", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"Numerator", "[", 
     RowBox[{"mix2new", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], 
    RowBox[{"(*", 
     RowBox[{"/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "->", "0"}], ",", 
        RowBox[{"ne", "->", "0"}], ",", 
        RowBox[{"np", "->", "0"}]}], "}"}]}], "*)"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"dm21", ">", "0"}], ",", 
      RowBox[{
       FractionBox["\[Pi]", "2"], ">", "\[Theta]", ">", "0"}], ",", 
      RowBox[{"x", ">", "0"}], ",", 
      RowBox[{"ne", ">", "0"}], ",", 
      RowBox[{"np", ">", "0"}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"Numerator", "[", 
    RowBox[{"mix2new", "[", 
     RowBox[{"[", 
      RowBox[{"2", ",", "1"}], "]"}], "]"}], "]"}], 
   RowBox[{"(*", 
    RowBox[{"/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", "->", "0"}], ",", 
       RowBox[{"ne", "->", "0"}], ",", 
       RowBox[{"np", "->", "0"}]}], "}"}]}], "*)"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"dm21", ">", "0"}], ",", 
     RowBox[{
      FractionBox["\[Pi]", "2"], ">", "\[Theta]", ">", "0"}], ",", 
     RowBox[{"x", ">", "0"}], ",", 
     RowBox[{"ne", ">", "0"}], ",", 
     RowBox[{"np", ">", "0"}]}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.982778460258947*^9, 3.982778516956204*^9}, {
  3.982778607757812*^9, 3.982778610371481*^9}},
 CellLabel->
  "In[627]:=",ExpressionUUID->"bc5bc7f4-2b9c-483b-8bfd-3a8ae006e2b8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"-", 
    RowBox[{"\[Sqrt]", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["dm21", "2"], "-", 
       RowBox[{"4", " ", 
        SqrtBox["2"], " ", "dm21", " ", "En", " ", "GF", " ", "ne", " ", 
        RowBox[{"cos", "(", 
         RowBox[{"2", " ", "\[Theta]"}], ")"}]}], "+", 
       RowBox[{"8", " ", 
        SqrtBox["2"], " ", "dm21", " ", "En", " ", "GF", " ", "np", " ", "x", 
        " ", 
        RowBox[{"sin", "(", 
         RowBox[{"2", " ", "\[Theta]"}], ")"}]}], "+", 
       RowBox[{"8", " ", 
        SuperscriptBox["En", "2"], " ", 
        SuperscriptBox["GF", "2"], " ", 
        SuperscriptBox["ne", "2"]}], "+", 
       RowBox[{"32", " ", 
        SuperscriptBox["En", "2"], " ", 
        SuperscriptBox["GF", "2"], " ", 
        SuperscriptBox["np", "2"], " ", 
        SuperscriptBox["x", "2"]}]}], ")"}]}]}], "-", 
   RowBox[{"dm21", " ", 
    RowBox[{"cos", "(", 
     RowBox[{"2", " ", "\[Theta]"}], ")"}]}], "+", 
   RowBox[{"2", " ", 
    SqrtBox["2"], " ", "En", " ", "GF", " ", "ne"}]}], 
  TraditionalForm]], "Output",
 CellChangeTimes->{{3.9827784616172237`*^9, 3.9827785175300426`*^9}, 
   3.982778611136897*^9},
 CellLabel->
  "Out[627]=",ExpressionUUID->"b2c170b1-d010-444f-a6df-b04df7b0cbda"],

Cell[BoxData[
 FormBox["2", TraditionalForm]], "Output",
 CellChangeTimes->{{3.9827784616172237`*^9, 3.9827785175300426`*^9}, 
   3.982778611140409*^9},
 CellLabel->
  "Out[628]=",ExpressionUUID->"aa094899-2624-4d89-a194-a44567069f50"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"solve11", "=", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"simp11", "==", "0"}], ",", "x", ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"dm21", ">", "0"}], ",", 
        RowBox[{
         FractionBox["\[Pi]", "2"], ">", "\[Theta]", ">", "0"}], ",", 
        RowBox[{"ne", ">", "0"}], ",", 
        RowBox[{"np", ">", "0"}]}], "}"}]}]}], "]"}], "//", 
   "FullSimplify"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "/.", "solve11"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"GF", "->", 
      RowBox[{"1.16", "*", 
       SuperscriptBox["10", 
        RowBox[{"-", "5"}]]}]}], " ", 
     RowBox[{"(*", 
      SuperscriptBox["GeV", 
       RowBox[{"-", "2"}]], "*)"}], ",", 
     RowBox[{"dm21", "->", 
      RowBox[{"2.5", "*", 
       SuperscriptBox["10", 
        RowBox[{"-", "3"}]], "*", 
       SuperscriptBox["10", 
        RowBox[{"-", "18"}]]}]}], ",", 
     RowBox[{"\[Theta]", "->", 
      RowBox[{"45", " ", "Degree"}]}], ",", 
